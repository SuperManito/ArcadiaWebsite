{
  "name": "arcadia-website",
  "type": "module",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": ">=22.0"
  },
  "scripts": {
    "build": "next build",
    "generate:openapi": "bun ./src/scripts/generate-docs.ts",
    "dev": "next dev",
    "info": "next info",
    "check": "fumadocs-mdx && next typegen && tsc --noEmit && rimraf tsconfig.tsbuildinfo",
    "postinstall": "fumadocs-mdx",
    "clean:cache": "rimraf .source && rimraf .next && rimraf node_modules/.cache/",
    "clean:build": "rimraf build && rimraf out && rimraf coverage",
    "clean:lock": "rimraf yarn.lock && rimraf pnpm-lock.yaml && rimraf package.lock.json",
    "clean:lib": "rimraf node_modules",
    "clean": "pnpm clean:build && pnpm clean:cache && pnpm clean:lock && pnpm clean:lib",
    "lint": "eslint",
    "lint:fix": "eslint --fix --ext .ts,tsx,js,jsx,mjs,mdx",
    "prepare": "husky"
  },
  "dependencies": {
    "@ai-sdk/react": "^3.0.170",
    "@ant-design/nextjs-registry": "^1.3.0",
    "@iconify/react": "^6.0.2",
    "@openrouter/ai-sdk-provider": "^2.8.1",
    "@orama/orama": "^3.1.18",
    "@orama/stopwords": "^3.1.18",
    "@orama/tokenizers": "^3.1.18",
    "@radix-ui/react-presence": "^1.1.5",
    "@takumi-rs/image-response": "^1.1.2",
    "ai": "^6.0.168",
    "antd": "^6.3.7",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "flexsearch": "^0.8.212",
    "fumadocs-core": "16.8.5",
    "fumadocs-mdx": "14.3.2",
    "fumadocs-openapi": "^10.8.1",
    "fumadocs-ui": "16.8.5",
    "hast-util-to-jsx-runtime": "^2.3.6",
    "lucide-react": "^1.11.0",
    "motion": "^12.38.0",
    "next": "16.2.4",
    "next-themes": "^0.4.6",
    "ogl": "^1.0.11",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "remark": "^15.0.1",
    "remark-gfm": "^4.0.1",
    "remark-rehype": "^11.1.2",
    "shiki": "^4.0.2",
    "tailwind-merge": "^3.5.0",
    "unist-util-visit": "^5.1.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^8.2.0",
    "@commitlint/cli": "^20.5.2",
    "@commitlint/config-conventional": "^20.5.0",
    "@next/eslint-plugin-next": "^16.2.4",
    "@tailwindcss/postcss": "^4.2.4",
    "@types/mdx": "^2.0.13",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.4",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "postcss": "^8.5.12",
    "rimraf": "^6.1.3",
    "tailwindcss": "^4.2.4",
    "tsx": "^4.21.0",
    "typescript": "~6.0.3"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,mjs}": "eslint --fix"
  }
}
