{
  "name": "arcadia-website",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "build": "next build",
    "build:openapi": "bun ./src/scripts/generate-docs.ts",
    "dev": "next dev",
    "check": "fumadocs-mdx && next typegen && tsc --noEmit && rimraf tsconfig.tsbuildinfo",
    "postinstall": "fumadocs-mdx",
    "clean:cache": "rimraf .source && rimraf .next && rimraf node_modules/.cache/",
    "clean:build": "rimraf build && rimraf out && rimraf coverage",
    "clean:lock": "rimraf yarn.lock && rimraf pnpm-lock.yaml && rimraf package.lock.json",
    "clean:lib": "rimraf node_modules",
    "clean": "pnpm clean:build && pnpm clean:cache && pnpm clean:lock && pnpm clean:lib",
    "lint": "eslint",
    "lint:fix": "eslint --fix --ext .ts,tsx,js,jsx,mjs,mdx"
  },
  "dependencies": {
    "@iconify/react": "^6.0.2",
    "@orama/orama": "^3.1.18",
    "@takumi-rs/image-response": "^0.71.7",
    "antd": "^6.3.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "fumadocs-core": "16.6.16",
    "fumadocs-mdx": "14.2.9",
    "fumadocs-openapi": "^10.3.18",
    "fumadocs-ui": "16.6.16",
    "lucide-react": "^0.577.0",
    "motion": "^12.36.0",
    "next": "16.1.6",
    "next-themes": "^0.4.6",
    "ogl": "^1.0.11",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "shiki": "^4.0.2",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^7.7.2",
    "@next/eslint-plugin-next": "^16.1.6",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/mdx": "^2.0.13",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.4",
    "postcss": "^8.5.8",
    "rimraf": "^6.1.3",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3"
  }
}
